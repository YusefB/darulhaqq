---
interface Props {
  author: string;
  site: 'SeekersGuidance' | 'IslamQA.org' | 'Ask Imam' | 'hadithanswers.com';
  url: string;
  excerpt: string;
}

const { author, site, url, excerpt } = Astro.props;
---
<figure class="quote">
  <blockquote>{excerpt}</blockquote>
  <figcaption>
    — {author}, <a href={url} rel="noopener external">{site}</a>
  </figcaption>
</figure>

<style>
  .quote {
    background: var(--bg-paper-light);
    border-left: 3px solid var(--gold);
    padding: 12px 16px;
    margin: 16px 0;
  }
  blockquote {
    font-size: 15px;
    line-height: 1.55;
    margin: 0 0 8px;
    color: var(--ink-primary);
  }
  figcaption {
    font-family: var(--sans);
    font-size: 12px;
    color: var(--ink-tertiary);
    letter-spacing: 0.02em;
  }
  figcaption a { color: var(--navy-link); }
</style>
