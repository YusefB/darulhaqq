---
interface Props {
  author: string;
  site: string;
  url?: string;
  excerpt: string;
  sourceType?: 'classical-sunni' | 'salafi' | 'classical-text' | 'academic';
}

const { author, site, url, excerpt, sourceType } = Astro.props;
const typeClass = sourceType ? `type-${sourceType}` : '';
---
<figure class={`quote ${typeClass}`}>
  <blockquote>{excerpt}</blockquote>
  <figcaption>
    — {author},{' '}
    {url ? <a href={url} rel="noopener external">{site}</a> : <span>{site}</span>}
  </figcaption>
</figure>

<style>
  .quote {
    background: var(--bg-paper-light);
    border-left: 3px solid var(--gold);
    padding: 12px 16px;
    margin: 16px 0;
  }
  /* Salafī sources: subtly different left rule (slate) so the side is clear at a glance */
  .quote.type-salafi {
    border-left-color: #6b7280;
    background: #fbfaf6;
  }
  /* Classical text without URL: neutral rule */
  .quote.type-classical-text {
    border-left-color: var(--ink-tertiary);
  }
  blockquote {
    font-size: 15px;
    line-height: 1.55;
    margin: 0 0 8px;
    color: var(--ink-primary);
  }
  figcaption {
    font-family: var(--sans);
    font-size: 12px;
    color: var(--ink-tertiary);
    letter-spacing: 0.02em;
  }
  figcaption a { color: var(--navy-link); }
</style>
