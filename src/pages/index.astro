---
import Base from '../layouts/Base.astro';
import TopicRow from '../components/TopicRow.astro';
import { getCollection } from 'astro:content';

const topics = (await getCollection('topics')).sort((a, b) => a.data.order - b.data.order);
---
<Base title="Dār al-Ḥaqq">
  <p class="lede">Refutations of common Salafī claims, anchored in the Qurʾān and the Sunnah.</p>
  <h2 class="section-label">Topics</h2>
  <ul class="topics">
    {topics.map(topic => <TopicRow topic={topic} />)}
  </ul>
</Base>

<style>
  .lede { margin-bottom: 24px; }
  .section-label {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-dim);
    margin: 24px 0 8px;
  }
  .topics { margin-top: 8px; padding: 0; list-style: none; }
</style>
