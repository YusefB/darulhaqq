---
import '../styles/global.css';

interface TocItem {
  id: string;
  label: string;
}

interface Props {
  title: string;
  description?: string;
  /** when true, renders a smaller H1 (used on inner pages) */
  compactHeader?: boolean;
  /** when provided, renders a sticky right-rail ToC on desktop */
  toc?: TocItem[];
}

const { title, description, compactHeader = false, toc } = Astro.props;
const fullTitle = title === 'Dār al-Ḥaqq' ? title : `${title} — Dār al-Ḥaqq`;
const pageDescription = description ?? 'Traditional Sunni Islam — the ʿaqīdah of the Salaf, the four madhāhib, and the Ashʿarī, Māturīdī, and Atharī (Ḥanbalī) schools.';
const currentPath = Astro.url.pathname;
const currentYear = new Date().getFullYear();

// Mark a nav link active if its href matches the current path exactly,
// or if currentPath starts with href + '/' (for nested topic detail pages).
const isActive = (href: string): boolean => {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.svg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:image" content="/og-image.svg" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <!-- Skip-to-content link (a11y) -->
    <a href="#main" class="skip-link">Skip to main content</a>

    <button class="menu-toggle" id="menu-toggle" type="button" aria-label="Open menu" aria-controls="sidebar" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>

    <div class="patch-flags" aria-label="In solidarity">
      <svg class="flag" viewBox="0 0 32 21" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Flag of Palestine">
        <rect width="32" height="7" y="0" fill="#000000"/>
        <rect width="32" height="7" y="7" fill="#ffffff"/>
        <rect width="32" height="7" y="14" fill="#009639"/>
        <polygon points="0,0 11,10.5 0,21" fill="#ce1126"/>
        <rect width="32" height="21" fill="none" stroke="rgba(0,0,0,0.2)" stroke-width="0.5"/>
      </svg>
    </div>

    <aside class="sidebar" id="sidebar" aria-label="Site sections">
      <div class="brand-block">
        <a href="/" class="brand-link">
          <p class="brand-ar" lang="ar" dir="rtl">دار الحق</p>
          <p class="brand-en">Dār al-Ḥaqq</p>
        </a>
      </div>

      <nav class="snav" aria-label="Read">
        <p class="snav-label">Read</p>
        <ul>
          <li><a href="/" class={isActive('/') ? 'active' : ''}>Origins</a></li>
          <li><a href="/history" class={isActive('/history') ? 'active' : ''}>History</a></li>
          <li><a href="/methodology" class={isActive('/methodology') ? 'active' : ''}>Methodology</a></li>
          <li><a href="/aqidah-differences" class={isActive('/aqidah-differences') ? 'active' : ''}>ʿAqīdah differences</a></li>
        </ul>
      </nav>

      <nav class="snav" aria-label="Topics">
        <p class="snav-label">Topics</p>
        <ul>
          <li><a href="/topics" class={currentPath === '/topics' ? 'active' : ''}>All topics</a></li>
          <li><a href="/topics/mawlid" class={isActive('/topics/mawlid') ? 'active' : ''}>Mawlid</a></li>
          <li><a href="/topics/group-dhikr" class={isActive('/topics/group-dhikr') ? 'active' : ''}>Group dhikr</a></li>
          <li><a href="/topics/visiting-graves" class={isActive('/topics/visiting-graves') ? 'active' : ''}>Visiting graves</a></li>
          <li><a href="/topics/tawassul" class={isActive('/topics/tawassul') ? 'active' : ''}>Tawassul</a></li>
          <li><a href="/topics/ashari-maturidi-creed" class={isActive('/topics/ashari-maturidi-creed') ? 'active' : ''}>Ashʿarī &amp; Māturīdī</a></li>
          <li><a href="/topics/ibn-taymiyyah-aqidah" class={isActive('/topics/ibn-taymiyyah-aqidah') ? 'active' : ''}>Ibn Taymiyyah</a></li>
          <li><a href="/topics/tarawih-rakat" class={isActive('/topics/tarawih-rakat') ? 'active' : ''}>Tarāwīḥ rakaʿāt</a></li>
          <li><a href="/topics/madhhab-system" class={isActive('/topics/madhhab-system') ? 'active' : ''}>Madhhab system</a></li>
        </ul>
      </nav>

      <nav class="snav" aria-label="Reference">
        <p class="snav-label">Reference</p>
        <ul>
          <li><a href="/scholars" class={isActive('/scholars') ? 'active' : ''}>Scholars</a></li>
          <li><a href="/library" class={isActive('/library') ? 'active' : ''}>Library</a></li>
        </ul>
      </nav>

      <nav class="snav" aria-label="About">
        <p class="snav-label">About</p>
        <ul>
          <li><a href="/search" class={isActive('/search') ? 'active' : ''}>Search</a></li>
          <li><a href="/sources" class={isActive('/sources') ? 'active' : ''}>Sources</a></li>
          <li><a href="/about" class={isActive('/about') ? 'active' : ''}>About</a></li>
        </ul>
      </nav>
    </aside>

    <div class="scrim" id="scrim" aria-hidden="true"></div>

    <main class={`content-wrap${toc && toc.length > 0 ? ' has-toc' : ''}`} id="main">
      <header class="page-head">
        {!compactHeader && (
          <>
            <p class="page-tagline">Traditional Sunni Islam — the ʿaqīdah of the Salaf, the four madhāhib, and the Ashʿarī, Māturīdī, and Atharī (Ḥanbalī) schools.</p>
            <div class="pattern" aria-hidden="true"></div>
          </>
        )}
      </header>

      <article class="content">
        <slot />
      </article>

      {toc && toc.length > 0 && (
        <nav class="toc" aria-label="On this page">
          <p class="toc-label">On this page</p>
          <ul>
            {toc.map((item) => (
              <li><a href={`#${item.id}`}>{item.label}</a></li>
            ))}
          </ul>
        </nav>
      )}

      <footer class="site-foot">
        <p class="duaa"><em>Allāhumma arinā al-ḥaqqa ḥaqqan wa-rzuqnā ittibāʿahu, wa-arinā al-bāṭila bāṭilan wa-rzuqnā ijtinābahu.</em></p>
        <div class="foot-links">
          <a href="https://github.com/YusefB/darulhaqq/issues/new" rel="noopener external">Suggest a topic</a>
          <span class="foot-sep" aria-hidden="true">·</span>
          <a href="https://github.com/YusefB/darulhaqq" rel="noopener external">View source</a>
          <span class="foot-sep" aria-hidden="true">·</span>
          <a href="/about">About</a>
        </div>
        <p class="foot-copy">© 2025–{currentYear} Dār al-Ḥaqq · CC BY 4.0</p>
        <p class="foot-note">
          Quoted excerpts: verbatim from cited sources. Framing prose: AI-drafted, maintainer-edited. <a href="/about#how-written">Read more</a>.
        </p>
      </footer>
    </main>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const sidebar = document.getElementById('sidebar');
      const scrim = document.getElementById('scrim');
      function setOpen(open: boolean) {
        sidebar?.classList.toggle('open', open);
        scrim?.classList.toggle('open', open);
        toggle?.setAttribute('aria-expanded', open ? 'true' : 'false');
        toggle?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      }
      toggle?.addEventListener('click', () => setOpen(!sidebar?.classList.contains('open')));
      scrim?.addEventListener('click', () => setOpen(false));
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setOpen(false); });

      // ToC intersection observer — highlight active section
      const tocLinks = document.querySelectorAll('.toc a');
      if (tocLinks.length > 0) {
        const headings = document.querySelectorAll('.content h3[id]');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              tocLinks.forEach((link) => link.classList.remove('active'));
              const activeLink = document.querySelector(`.toc a[href="#${entry.target.id}"]`);
              activeLink?.classList.add('active');
            }
          });
        }, { rootMargin: '-20% 0px -70% 0px' });
        headings.forEach((h) => observer.observe(h));
      }
    </script>

    <style>
      /* === Skip link (a11y) === */
      .skip-link {
        position: absolute;
        left: -9999px;
        top: auto;
        width: 1px;
        height: 1px;
        overflow: hidden;
        font-family: var(--sans);
        font-size: 14px;
        background: var(--navy);
        color: #fff;
        padding: 8px 16px;
        border-radius: 0 0 6px 0;
        z-index: 200;
        text-decoration: none;
      }
      .skip-link:focus {
        position: fixed;
        top: 0;
        left: 0;
        width: auto;
        height: auto;
        overflow: visible;
      }

      /* === Sidebar === */
      .sidebar {
        position: fixed;
        top: 0;
        left: 0;
        width: 240px;
        height: 100vh;
        background: var(--bg-paper);
        border-right: 1px solid var(--rule-warm);
        padding: 32px 20px 24px;
        overflow-y: auto;
        z-index: 20;
      }
      .brand-block { margin-bottom: 28px; padding-bottom: 16px; border-bottom: 1px solid var(--rule-warm-soft); }
      .brand-link { text-decoration: none; display: block; }
      .brand-ar { font-family: var(--arabic); font-size: 22px; color: var(--navy); margin: 0 0 2px; font-weight: 700; }
      .brand-en { font-family: var(--sans); font-size: 18px; color: var(--navy); font-weight: 600; letter-spacing: -0.01em; margin: 0; }

      .snav { margin-bottom: 24px; }
      .snav-label {
        font-family: var(--sans);
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--gold-dim);
        margin: 0 0 6px;
      }
      .snav ul { padding: 0; list-style: none; margin: 0; }
      .snav li { margin: 0; }
      .snav a {
        display: block;
        font-family: var(--serif);
        font-size: 15px;
        color: var(--ink-primary);
        text-decoration: none;
        padding: 4px 0 4px 8px;
        border-left: 2px solid transparent;
        line-height: 1.35;
      }
      .snav a:hover { color: var(--navy-link); }
      .snav a.active {
        color: var(--navy);
        font-weight: 600;
        border-left-color: var(--gold);
      }

      /* === Mobile menu toggle === */
      .menu-toggle {
        position: fixed;
        top: 14px;
        left: 14px;
        width: 44px;
        height: 44px;
        background: var(--bg-paper);
        border: 1px solid var(--rule-warm);
        border-radius: 6px;
        cursor: pointer;
        z-index: 30;
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 4px;
        padding: 0;
      }
      .menu-toggle .bar { width: 18px; height: 2px; background: var(--navy); display: block; }

      /* === Solidarity flag patches (top-right corner) === */
      .patch-flags {
        position: fixed;
        top: 14px;
        right: 14px;
        display: flex;
        gap: 6px;
        z-index: 25;
        pointer-events: none;
      }
      .patch-flags .flag {
        width: 42px;
        height: 28px;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.18);
        display: block;
      }
      @media (max-width: 600px) {
        .patch-flags { top: 10px; right: 10px; gap: 4px; }
        .patch-flags .flag { width: 34px; height: 23px; }
      }

      .scrim {
        position: fixed;
        inset: 0;
        background: rgba(24, 24, 24, 0.4);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.15s ease;
        z-index: 15;
      }
      .scrim.open { opacity: 1; pointer-events: auto; }

      /* === Content wrap (normal) === */
      .content-wrap {
        margin-left: 240px;
        max-width: 720px;
        padding: 24px 32px 0;
      }

      /* === Content wrap with right-rail ToC === */
      @media (min-width: 1100px) {
        .content-wrap.has-toc {
          display: grid;
          grid-template-columns: 1fr 200px;
          grid-template-rows: auto 1fr auto;
          gap: 0 48px;
          max-width: 980px;
        }
        /* page-head spans full width */
        .content-wrap.has-toc > .page-head {
          grid-column: 1 / -1;
        }
        /* footer spans full width */
        .content-wrap.has-toc > .site-foot {
          grid-column: 1 / -1;
        }
        /* ToC in the right column */
        .content-wrap.has-toc > .toc {
          grid-column: 2;
          grid-row: 2;
        }
        /* Article in the left column */
        .content-wrap.has-toc > .content {
          grid-column: 1;
          grid-row: 2;
          min-width: 0;
        }
      }

      /* === ToC === */
      .toc {
        position: sticky;
        top: 32px;
        align-self: start;
        font-family: var(--sans);
        font-size: 13px;
        border-left: 1px solid var(--rule-warm-soft);
        padding-left: 16px;
      }
      .toc-label {
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--gold-dim);
        font-weight: 600;
        margin: 0 0 8px;
      }
      .toc ul { list-style: none; padding: 0; margin: 0; }
      .toc li { margin-bottom: 6px; }
      .toc a {
        color: var(--ink-secondary);
        text-decoration: none;
        line-height: 1.35;
        display: block;
        padding: 2px 0 2px 8px;
        border-left: 2px solid transparent;
        margin-left: -8px;
      }
      .toc a:hover { color: var(--navy-link); }
      .toc a.active { color: var(--navy); border-left-color: var(--gold); font-weight: 600; }
      @media (max-width: 1099px) {
        .content-wrap.has-toc { grid-template-columns: 1fr; }
        .toc { display: none; }
      }

      .page-head { margin-bottom: 16px; }
      .page-tagline { font-style: italic; color: var(--ink-secondary); font-size: 15px; margin: 16px 0 14px; }
      .pattern {
        height: 4px;
        margin-bottom: 8px;
        background: repeating-linear-gradient(90deg, var(--gold) 0, var(--gold) 6px, transparent 6px, transparent 12px);
      }
      .content {
        padding: 12px 0 48px;
      }
      /* Typography polish — inner page headings */
      .content h2 { font-size: 28px; line-height: 1.2; }
      .content h3 {
        font-size: 19px;
        font-weight: 600;
        letter-spacing: -0.01em;
        text-transform: none;
        color: var(--navy);
        margin: 32px 0 10px;
      }

      .site-foot {
        border-top: 1px solid var(--rule-warm);
        margin-top: 64px;
        padding: 24px 0 48px;
      }
      .site-foot .duaa { font-size: 14px; color: var(--ink-secondary); margin-bottom: 10px; }
      .foot-links {
        font-family: var(--sans);
        font-size: 13px;
        color: var(--ink-tertiary);
        margin-bottom: 6px;
        display: flex;
        flex-wrap: wrap;
        gap: 0 6px;
        align-items: center;
      }
      .foot-links a { color: var(--navy-link); text-decoration: none; }
      .foot-links a:hover { text-decoration: underline; }
      .foot-sep { color: var(--rule-warm); }
      .foot-copy {
        font-family: var(--sans);
        font-size: 12px;
        color: var(--ink-tertiary);
        margin: 0 0 8px;
      }
      .foot-note {
        font-family: var(--sans);
        font-size: 11px;
        color: var(--ink-tertiary);
        font-style: italic;
        margin: 0;
        line-height: 1.5;
        max-width: 640px;
      }
      .foot-note a { color: var(--navy-link); text-decoration: none; font-style: normal; }
      .foot-note a:hover { text-decoration: underline; }

      /* === Responsive === */
      @media (max-width: 899px) {
        .menu-toggle { display: flex; }
        .sidebar {
          transform: translateX(-100%);
          transition: transform 0.2s ease;
        }
        .sidebar.open { transform: translateX(0); }
        .content-wrap { margin-left: 0; padding: 64px 24px 0; }
      }

      @media (prefers-reduced-motion: reduce) {
        .sidebar, .scrim { transition: none; }
      }
    </style>
  </body>
</html>
